---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="About - Tropic Roastery" description="About page placeholder for the Astro storefront setup.">
  <main class="px-4 py-24">
    <section class="mx-auto max-w-3xl rounded-3xl border border-neutral-200 bg-white p-8 text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-orange-500">About</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight text-neutral-900">About Tropic Roastery</h1>
      <p class="mt-4 text-sm leading-7 text-neutral-500">
        This page is a starter placeholder for the new Astro structure.
      </p>
    </section>
    <Footer />
  </main>
</BaseLayout>

