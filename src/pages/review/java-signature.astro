---
import MainLayout from "../../layouts/MainLayout.astro";
import Container from "../../components/Container.astro";
import Badge from "../../components/ui/Badge.astro";
import Button from "../../components/ui/Button.astro";

const review = {
  title: "Review Java Signature: Kopi Harian Paling Seimbang",
  productName: "Java Signature Arabica",
  rating: 4.8,
  price: "Rp 154.000",
  image: "https://images.unsplash.com/photo-1495474472201-497192cf91a3?auto=format&fit=crop&w=1200&q=80&fm=webp",
  summary: "Java Signature adalah 'daily driver' yang sempurna. Memiliki body yang cukup tebal dengan sentuhan karamel dan cokelat yang menenangkan. Tidak terlalu asam, tidak terlalu pahit.",
  pros: ["Body seimbang", "Rendah asam", "Aroma cokelat kuat", "Harga terjangkau untuk kualitasnya"],
  cons: ["Kurang 'kompleks' bagi pencinta specialty tingkat lanjut", "Karakter rasa cenderung stabil/datar"],
  details: [
    {
      title: "Profil Rasa",
      content: "Dominasi rasa cokelat susu dan karamel bakar. Ada sedikit rasa kacang di akhir seduhan. Sangat nyaman untuk diminum setiap hari tanpa membuat perut kembung."
    },
    {
      title: "Rekomendasi Seduh",
      content: "Cocok untuk hampir semua metode. Mulai dari French Press, Tubruk, hingga Espresso. Jika menggunakan susu, rasa cokelatnya akan semakin menonjol."
    },
    {
      title: "Asal-Usul",
      content: "Berasal dari perkebunan di Jawa Barat, diproses dengan metode Semi-Washed (Giling Basah) untuk mempertahankan body kopi yang khas Indonesia."
    }
  ],
  useCase: "Ideal untuk kopi pagi di kantor atau teman kerja yang tidak membosankan."
};
---

<MainLayout 
  title={review.title}
  description={review.summary}
>
  <article class="ds-section">
    <Container as="div">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
        <div class="space-y-6">
          <Badge label="Most Popular" />
          <h1 class="text-4xl font-bold tracking-tight text-neutral-900 md:text-5xl">{review.title}</h1>
          <div class="flex items-center gap-2 text-lg font-bold text-orange-500">
            <span>★</span>
            <span>{review.rating} / 5.0</span>
          </div>
          <p class="text-lg leading-relaxed text-neutral-600">{review.summary}</p>
          <div class="flex flex-col gap-4 pt-4 sm:flex-row">
            <Button href="#beli" label="Beli Sekarang" variant="primary" class="flex-1" />
            <Button href="/best/kopi-arabika-terbaik" label="Lihat Pilihan Lain" variant="outline" class="flex-1" />
          </div>
        </div>
        <div class="overflow-hidden rounded-[2.5rem] border border-neutral-200">
          <img src={review.image} alt={review.productName} class="aspect-[4/3] w-full object-cover" />
        </div>
      </div>

      <div class="mt-16 rounded-3xl bg-neutral-900 p-8 text-white md:p-12">
        <h2 class="text-2xl font-bold">Mengapa Ini Paling Populer?</h2>
        <p class="mt-4 text-neutral-400 leading-relaxed">
          Konsistensi adalah kunci. Java Signature memberikan rasa yang sama di setiap seduhan. Bagi banyak orang, inilah kopi yang mereka butuhkan untuk memulai hari tanpa harus pusing memikirkan profil rasa yang terlalu rumit.
        </p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-2">
        <div class="rounded-3xl border border-neutral-200 bg-white p-8">
          <h3 class="text-xl font-bold text-neutral-900">Kelebihan</h3>
          <ul class="mt-4 space-y-3">
            {review.pros.map(pro => (
              <li class="flex items-center gap-3 text-sm text-neutral-600">
                <span class="text-green-500">✓</span> {pro}
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-3xl border border-neutral-200 bg-white p-8">
          <h3 class="text-xl font-bold text-neutral-900">Kekurangan</h3>
          <ul class="mt-4 space-y-3">
            {review.cons.map(con => (
              <li class="flex items-center gap-3 text-sm text-neutral-600">
                <span class="text-red-400">✕</span> {con}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="mt-24 max-w-3xl mx-auto space-y-16">
        {review.details.map(section => (
          <section class="space-y-4">
            <h2 class="text-2xl font-bold text-neutral-900">{section.title}</h2>
            <p class="text-lg leading-relaxed text-neutral-600">{section.content}</p>
          </section>
        ))}
      </div>

      <div class="mt-24 border-t border-neutral-200 pt-16">
        <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
          <div>
            <h2 class="text-3xl font-bold text-neutral-900">Kesimpulan</h2>
            <p class="mt-4 text-lg text-neutral-600">Kopi aman, enak, dan pasti disukai semua orang.</p>
          </div>
          <Button href="#beli" label="Beli Sekarang" variant="primary" size="lg" />
        </div>
      </div>
    </Container>
  </article>
</MainLayout>
