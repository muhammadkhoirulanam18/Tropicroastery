---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../sections/Hero.astro";
import FeaturedArticlesSection from "../sections/FeaturedArticlesSection.astro";
import CategoriesSection from "../sections/CategoriesSection.astro";
import BrewingGuideHighlight from "../sections/BrewingGuideHighlight.astro";
import CoffeeBeansSection from "../sections/CoffeeBeansSection.astro";
import CoffeeGearSection from "../sections/CoffeeGearSection.astro";
import ComparisonSection from "../sections/ComparisonSection.astro";
import RoasteryStory from "../sections/RoasteryStory.astro";
import NewsletterCTA from "../sections/NewsletterCTA.astro";
---

<MainLayout
  title="Tropic Roastery — Specialty Coffee dari Nusantara"
  description="Kopi single origin pilihan dari dataran tinggi Indonesia. Disangrai kecil, dikirim segar, dinikmati sepenuhnya."
>
  {/* 1. Hero — establish brand + primary CTA */}
  <Hero />

  {/* 2. Coffee Gear — technical precision showcase */}
  <CoffeeGearSection />

  {/* 2.5. Comparison Section — editorial gear matchup for affiliate CTR */}
  <ComparisonSection />

  {/* 3. Coffee Beans — curated sensory experience */}
  <CoffeeBeansSection />

  {/* 4. Categories — navigation into product funnel */}
  <CategoriesSection />

  {/* 5. Roastery Story — brand trust, links to /about */}
  <RoasteryStory />

  {/* 6. Featured Journal — attract SEO traffic, link to /best & /review */}
  <FeaturedArticlesSection />

  {/* 7. Newsletter CTA — engagement + retention */}
  <NewsletterCTA />
</MainLayout>
