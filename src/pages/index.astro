---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProductGrid from "../components/ProductGrid.astro";
import Footer from "../components/Footer.astro";

const products = [
  {
    title: "Coffee Grinder",
    price: "$89",
    description: "Compact grinder with a clean form factor and smooth daily workflow.",
    image: "https://images.unsplash.com/photo-1511920170033-f8396924c348?auto=format&fit=crop&w=1200&q=80",
    href: "#",
  },
  {
    title: "Pour Over Set",
    price: "$49",
    description: "Simple brewing kit for a calm, focused coffee ritual at home.",
    image: "https://images.unsplash.com/photo-1495474472201-497192cf91a3?auto=format&fit=crop&w=1200&q=80",
    href: "#",
  },
  {
    title: "Espresso Machine",
    price: "$399",
    description: "A premium machine for users who want stronger visual presence and performance.",
    image: "https://images.unsplash.com/photo-1459755486867-b55449bb39ff?auto=format&fit=crop&w=1200&q=80",
    href: "#",
  },
];
---

<BaseLayout
  title="Tropic Roastery - Modern Coffee Storefront"
  description="Minimal modern storefront built with Astro and Tailwind CSS."
>
  <main>
    <Hero />
    <ProductGrid products={products} />
    <section id="about" class="px-4 py-16">
      <div class="mx-auto max-w-3xl rounded-3xl border border-neutral-200 bg-white p-8 text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-orange-500">About</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight text-neutral-900">Simple setup, clear structure</h2>
        <p class="mt-4 text-sm leading-7 text-neutral-500">
          This starter keeps the layout focused on hero, product grid, and footer so the foundation stays lean.
        </p>
      </div>
    </section>
    <Footer />
  </main>
</BaseLayout>
