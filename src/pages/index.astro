---

<BaseLayout
  title="Tropic Roastery | Premium Minimal Coffee Storefront"
  description="A premium minimal coffee storefront built with Astro and Tailwind CSS. Fast, responsive, SEO-ready, and reusable."
>
  <main>
    <Hero />

    <section id="story" class="ds-section pt-0">
      <div class="ds-container">
        <div class="grid gap-8 lg:grid-cols-2 lg:items-center">
          <div class="space-y-5">
            <SectionHeader
              kicker="Brand story"
              title="A calm coffee brand with a clear product story."
              description="Tropic Roastery is built around minimal presentation, transparent origin, and a clean shopping experience that keeps the beans front and center."
            />
            <div class="flex flex-wrap gap-3 pt-2">
              <Badge label="Best Choice" />
              <Badge label="Cocok untuk Pemula" tone="neutral" />
            </div>
          </div>

          <div class="ds-surface overflow-hidden p-0">
            <img
              src="https://images.unsplash.com/photo-1447933601403-0c6688de566e?auto=format&fit=crop&w=1400&q=80&fm=webp"
              alt="Minimal coffee roastery interior"
              class="aspect-[4/3] w-full object-cover"
              loading="lazy"
              decoding="async"
            />
            <div class="grid gap-4 p-6 sm:grid-cols-3">
              <div>
                <p class="text-2xl font-semibold text-neutral-900">24h</p>
                <p class="text-sm text-neutral-500">Roast to ship</p>
              </div>
              <div>
                <p class="text-2xl font-semibold text-neutral-900">6</p>
                <p class="text-sm text-neutral-500">Core collections</p>
              </div>
              <div>
                <p class="text-2xl font-semibold text-neutral-900">1</p>
                <p class="text-sm text-neutral-500">Clear brand system</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="beans" class="ds-section pt-0">
      <div class="ds-container">
        <SectionHeader
          kicker="Featured beans"
          title="Coffee cards designed to convert without clutter."
          description="Every card is reusable, carries flavor signals, and keeps the product story visible on mobile and desktop."
        />
        <div class="mt-10 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {featuredBeans.map((bean) => <ProductCard {...bean} />)}
        </div>
      </div>
    </section>

    <section id="categories" class="ds-section pt-0">
      <div class="ds-container">
        <SectionHeader
          kicker="Categories"
          title="Browse by brewing intent."
          description="Simple category cards keep the structure clear and make the page easier to scan."
        />
        <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {categories.map((category) => (
            <article class="ds-card ds-card-hover p-6">
              <p class="ds-kicker">{category.count}</p>
              <h3 class="mt-3 text-xl font-semibold tracking-tight text-neutral-900">{category.title}</h3>
              <p class="mt-3 text-sm leading-7 text-neutral-500">{category.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="guides" class="ds-section pt-0">
      <div class="ds-container">
        <SectionHeader
          kicker="Brew guides"
          title="Short, useful brewing content."
          description="Educational content helps search traffic while still moving readers toward products."
        />
        <div class="mt-10 grid gap-6 lg:grid-cols-3">
          {guides.map((guide, index) => (
            <article class="ds-surface p-6">
              <p class="ds-kicker">0{index + 1}</p>
              <h3 class="mt-3 text-xl font-semibold tracking-tight text-neutral-900">{guide.title}</h3>
              <p class="mt-3 text-sm leading-7 text-neutral-500">{guide.description}</p>
              <p class="mt-5 text-sm font-medium text-orange-500">{guide.readTime}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="why" class="ds-section pt-0">
      <div class="ds-container">
        <SectionHeader
          kicker="Why choose us"
          title="Built to feel premium, but easy to understand."
          description="The layout is intentionally calm. Each block exists to improve scanning, trust, or conversion."
        />
        <div class="mt-10 grid gap-6 lg:grid-cols-3">
          {benefits.map((benefit) => (
            <article class="ds-card ds-card-hover p-6">
              <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-orange-50 text-lg font-semibold text-orange-500">
                OK
              </div>
              <h3 class="mt-4 text-xl font-semibold tracking-tight text-neutral-900">{benefit.title}</h3>
              <p class="mt-3 text-sm leading-7 text-neutral-500">{benefit.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="testimonials" class="ds-section pt-0">
      <div class="ds-container">
        <SectionHeader
          kicker="Testimonials"
          title="Proof from coffee drinkers."
          description="Short testimonials keep the section light while still building trust."
        />
        <div class="mt-10 grid gap-6 lg:grid-cols-3">
          {testimonials.map((testimonial) => (
            <figure class="ds-surface p-6">
              <div class="flex gap-1 text-orange-500" aria-hidden="true">
                <span>5/5</span>
              </div>
              <blockquote class="mt-4 text-sm leading-7 text-neutral-700">
                "{testimonial.quote}"
              </blockquote>
              <figcaption class="mt-5">
                <p class="font-medium text-neutral-900">{testimonial.name}</p>
                <p class="text-sm text-neutral-500">{testimonial.role}</p>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section id="gallery" class="ds-section pt-0">
      <div class="ds-container">
        <SectionHeader
          kicker="Gallery"
          title="Visual cues that keep the brand premium."
          description="A light gallery gives the page atmosphere without relying on animation or video."
        />
        <div class="mt-10 grid grid-cols-2 gap-4 md:grid-cols-3">
          {gallery.map((item) => (
            <figure class="group overflow-hidden rounded-3xl border border-neutral-200 bg-white">
              <img
                src={item.image}
                alt={item.label}
                class="aspect-[4/3] w-full object-cover transition duration-300 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
              <figcaption class="px-4 py-3 text-sm text-neutral-500">{item.label}</figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section id="newsletter" class="ds-section pt-0">
      <div class="ds-container">
        <div class="grid gap-8 lg:grid-cols-2 lg:items-center">
          <div>
            <SectionHeader
              kicker="Newsletter"
              title="Get brewing notes and new bean drops."
              description="A simple email capture section keeps the homepage conversion-friendly without adding clutter."
            />
          </div>

          <form class="ds-surface p-6 sm:p-8" action="#" method="post">
            <label class="block">
              <span class="mb-2 block text-sm font-medium text-neutral-900">Email address</span>
              <input
                type="email"
                name="email"
                placeholder="you@example.com"
                class="w-full rounded-full border border-neutral-200 bg-white px-5 py-3 text-sm text-neutral-900 outline-none transition placeholder:text-neutral-400 focus:border-orange-400"
              />
            </label>
            <div class="mt-4 flex flex-col gap-3 sm:flex-row">
              <button type="submit" class="ds-button-primary w-full sm:w-auto">
                Subscribe
              </button>
              <p class="text-sm leading-7 text-neutral-500 sm:self-center">
                No spam. Only roast updates and useful brewing notes.
              </p>
            </div>
          </form>
        </div>
      </div>
    </section>

    <Cta
      primaryHref="#beans"
      secondaryHref="#newsletter"
    />

    <section id="faq" class="ds-section pt-0">
      <div class="ds-container">
        <SectionHeader
          kicker="FAQ"
          title="Common questions, answered clearly."
          description="Expandable details keep the page lightweight and easy to scan."
        />
        <div class="mt-10 space-y-4">
          {faqItems.map((item) => (
            <details class="ds-surface group p-6">
              <summary class="cursor-pointer list-none text-base font-medium text-neutral-900">
                {item.question}
              </summary>
              <p class="mt-3 text-sm leading-7 text-neutral-500">
                {item.answer}
              </p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <SiteFooter />
  </main>
</BaseLayout>
