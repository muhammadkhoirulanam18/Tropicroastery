---
import MainLayout from "../../layouts/MainLayout.astro";
import Container from "../../components/Container.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import Badge from "@/components/ui/Badge.astro";

const articles = [
  {
    title: "Cara Menyeduh Kopi V60: Panduan Lengkap untuk Hasil Maksimal",
    image: "/images/v60-brewing.png",
    imageAlt: "Cara Menyeduh Kopi V60",
    description: "Pelajari teknik menyeduh kopi V60 yang benar untuk mengeluarkan profil rasa yang bersih, cerah, dan aromatik.",
    href: "/blog/cara-menyeduh-kopi-v60",
    date: "11 Mei 2026",
    category: "Tutorial Seduh"
  },
  {
    title: "Perbedaan Kopi Arabika dan Robusta: Mana yang Lebih Cocok untuk Anda?",
    image: "/images/arabica-vs-robusta.png",
    imageAlt: "Perbedaan Kopi Arabica dan Robusta",
    description: "Pahami perbedaan mendasar antara kopi Arabika dan Robusta mulai dari rasa, kadar kafein, hingga harga.",
    href: "/blog/perbedaan-kopi-arabika-dan-robusta",
    date: "11 Mei 2026",
    category: "Pengetahuan Kopi"
  },
  {
    title: "Cara Menyimpan Biji Kopi agar Tetap Segar Selama Berbulan-bulan",
    image: "/images/coffee-storage.png",
    imageAlt: "Cara Menyimpan Biji Kopi",
    description: "Jangan biarkan kopi mahal Anda menjadi apek. Ikuti panduan cara menyimpan biji kopi yang benar.",
    href: "/blog/cara-menyimpan-biji-kopi",
    date: "11 Mei 2026",
    category: "Tips & Trik"
  }
];
---

<MainLayout 
  title="Journal & Brewing Notes | Tropic Roastery"
  description="Kumpulan artikel seputar kopi, teknik menyeduh, dan tips menjaga kualitas biji kopi Anda."
>
  <section class="py-24 md:py-36">
    <Container as="div">
      <header class="max-w-3xl">
        <div class="mb-5">
          <Badge label="Journal" />
        </div>
        <h1 class="mt-4 font-display text-4xl font-bold tracking-tight text-stone-900 md:text-5xl lg:text-6xl">
          Brewing Notes & Stories
        </h1>
        <p class="mt-6 text-xl text-stone-500 leading-relaxed">
          Eksplorasi dunia kopi melalui panduan seduh, ulasan produk, dan cerita dari balik meja sangrai kami.
        </p>
      </header>

      <div class="mt-20 grid gap-x-8 gap-y-16 md:grid-cols-2 lg:grid-cols-3">
        {articles.map((article) => (
          <ArticleCard
            image={article.image}
            imageAlt={article.imageAlt}
            title={article.title}
            excerpt={article.description} 
            href={article.href}
            category={article.category}
            date={article.date}
          />
        ))}
      </div>
    </Container>
  </section>
</MainLayout>
