---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | Tropic Roastery" description="Contact Tropic Roastery">
  <main class="ds-section">
    <div class="ds-container max-w-3xl">
      <p class="ds-kicker">Contact</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-neutral-900">
        Contact Tropic Roastery
      </h1>
      <p class="mt-4 text-sm leading-7 text-neutral-500">
        This page is reserved for contact and partnership details.
      </p>
    </div>
  </main>
</BaseLayout>
