---
import MainLayout from "../layouts/MainLayout.astro";
import Container from "../components/Container.astro";
import Badge from "../components/ui/Badge.astro";
---

<MainLayout 
  title="Contact Us | Tropic Roastery" 
  description="Hubungi tim Tropic Roastery untuk pertanyaan seputar produk, kemitraan, atau sekadar berbagi cerita tentang kopi favorit Anda."
>
  <section class="py-24 md:py-36">
    <Container as="div">
      <div class="grid gap-16 lg:grid-cols-2 lg:items-start">
        <header class="space-y-6">
          <Badge label="Contact Us" tone="neutral" />
          <h1 class="font-display text-4xl font-bold tracking-tight text-stone-900 md:text-5xl lg:text-6xl">
            Mari Bicara Kopi.
          </h1>
          <p class="text-xl text-stone-500 leading-relaxed">
            Punya pertanyaan seputar cara seduh, pesanan, atau ingin bekerja sama? Kami selalu senang mendengar dari Anda.
          </p>

          <div class="mt-12 space-y-8">
            <div>
              <h3 class="text-xs font-semibold uppercase tracking-widest text-stone-400">Email</h3>
              <p class="mt-2 text-xl font-medium text-stone-900">mkhoirulanam920@gmail.com</p>
            </div>
            <div>
              <h3 class="text-xs font-semibold uppercase tracking-widest text-stone-400">Alamat Sangrai</h3>
              <p class="mt-2 text-xl font-medium text-stone-900">Yogyakarta, Indonesia</p>
              <p class="text-stone-500">Tersedia untuk kunjungan dengan janji temu.</p>
            </div>
            <div>
              <h3 class="text-xs font-semibold uppercase tracking-widest text-stone-400">Socials</h3>
              <div class="mt-4 flex gap-6">
                <a href="#" class="text-stone-600 hover:text-orange-600 transition">Instagram</a>
                <a href="#" class="text-stone-600 hover:text-orange-600 transition">WhatsApp</a>
                <a href="#" class="text-stone-600 hover:text-orange-600 transition">TikTok</a>
              </div>
            </div>
          </div>
        </header>

        <form class="rounded-[2.5rem] border border-stone-200 bg-white p-8 md:p-12 shadow-sm" action="#" method="post">
          <div class="grid gap-6">
            <div class="grid gap-2">
              <label for="name" class="text-sm font-semibold text-stone-900">Nama Lengkap</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                placeholder="Masukkan nama Anda"
                class="w-full rounded-2xl border border-stone-200 bg-stone-50 px-5 py-4 text-sm outline-none focus:border-orange-500"
                required
              />
            </div>
            <div class="grid gap-2">
              <label for="email" class="text-sm font-semibold text-stone-900">Alamat Email</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                placeholder="email@contoh.com"
                class="w-full rounded-2xl border border-stone-200 bg-stone-50 px-5 py-4 text-sm outline-none focus:border-orange-500"
                required
              />
            </div>
            <div class="grid gap-2">
              <label for="subject" class="text-sm font-semibold text-stone-900">Subjek</label>
              <select 
                id="subject" 
                name="subject" 
                class="w-full rounded-2xl border border-stone-200 bg-stone-50 px-5 py-4 text-sm outline-none focus:border-orange-500"
              >
                <option>Tanya Produk</option>
                <option>Pesanan</option>
                <option>Kemitraan (B2B)</option>
                <option>Lainnya</option>
              </select>
            </div>
            <div class="grid gap-2">
              <label for="message" class="text-sm font-semibold text-stone-900">Pesan</label>
              <textarea 
                id="message" 
                name="message" 
                rows="5" 
                placeholder="Apa yang bisa kami bantu?"
                class="w-full rounded-2xl border border-stone-200 bg-stone-50 px-5 py-4 text-sm outline-none focus:border-orange-500"
                required
              ></textarea>
            </div>
            <button type="submit" class="ds-button-primary mt-4 w-full justify-center py-5 text-base">
              Kirim Pesan
            </button>
          </div>
        </form>
      </div>
    </Container>
  </section>
</MainLayout>
