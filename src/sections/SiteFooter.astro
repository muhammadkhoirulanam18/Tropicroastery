---
import Container from "../components/Container.astro";

const links = [
  { href: "/", label: "Home" },
  { href: "/best/kopi-arabika-terbaik", label: "Beans" },
  { href: "/blog", label: "Journal" },
  { href: "/about", label: "Story" },
  { href: "/contact", label: "Contact" },
];
---

<footer class="border-t border-stone-100 py-16 md:py-24" id="footer">
  <Container as="div">
    <div class="flex flex-col gap-12 md:flex-row md:justify-between">
      <!-- Wordmark & tagline -->
      <div class="max-w-sm">
        <p class="font-display text-lg font-semibold text-stone-900">Tropic Roastery</p>
        <p class="mt-3 text-sm text-stone-500 leading-relaxed">
          Kopi single origin pilihan dari dataran tinggi Indonesia. Disangrai kecil, dikirim segar.
        </p>
      </div>

      <!-- Links -->
      <div class="flex gap-16">
        <div class="space-y-4">
          <p class="ds-kicker">Navigation</p>
          <ul class="space-y-2.5">
            {links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-stone-500 hover:text-stone-900">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="space-y-4">
          <p class="ds-kicker">Contact</p>
          <ul class="space-y-2.5 text-sm text-stone-500">
            <li>mkhoirulanam920@gmail.com</li>
            <li>Yogyakarta, Indonesia</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-16 border-t border-stone-100 pt-6 text-xs text-stone-400">
      <p>© 2026 Tropic Roastery. All rights reserved.</p>
    </div>
  </Container>
</footer>
