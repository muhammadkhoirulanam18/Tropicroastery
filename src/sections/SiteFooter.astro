---
import Container from "../components/Container.astro";
---

<footer class="ds-section border-t border-neutral-200 bg-white/70" id="contact">
  <Container as="div">
    <div class="grid gap-10 lg:grid-cols-[1.4fr_0.6fr] lg:items-end">
      <div class="max-w-2xl">
        <p class="ds-kicker">Tropic Roastery</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-neutral-900 md:text-4xl">
          Premium minimal coffee storefront, built for speed and clarity.
        </h2>
        <p class="mt-4 text-sm leading-7 text-neutral-500">
          Clean architecture, reusable components, and a storefront layout that keeps the focus on beans, brewing, and conversion.
        </p>
      </div>

      <div class="space-y-3 text-sm text-neutral-500 lg:text-right">
        <p>Contact: mkhoirulanam920@gmail.com</p>
        <p>Open daily: 08.00 - 18.00</p>
        <p>Designed with Astro + Tailwind.</p>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-4 border-t border-neutral-200 pt-6 text-sm text-neutral-500 md:flex-row md:items-center md:justify-between">
      <p>(c) 2026 Tropic Roastery. All rights reserved.</p>
      <div class="flex flex-wrap gap-4">
        <a href="#story" class="transition hover:text-neutral-900">Story</a>
        <a href="#beans" class="transition hover:text-neutral-900">Beans</a>
        <a href="#faq" class="transition hover:text-neutral-900">FAQ</a>
      </div>
    </div>
  </Container>
</footer>
