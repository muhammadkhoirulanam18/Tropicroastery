---
import Container from "../components/Container.astro";

interface Props {
  productA?: { name: string; image: string };
  productB?: { name: string; image: string };
  href?: string;
}

const {
  productA = { name: "Kintamani", image: "https://images.unsplash.com/photo-1559056199-641a0ac8b55e?auto=format&fit=crop&w=400&q=80&fm=webp" },
  productB = { name: "Java Signature", image: "https://images.unsplash.com/photo-1495474472201-497192cf91a3?auto=format&fit=crop&w=400&q=80&fm=webp" },
  href = "/comparison/kintamani-vs-java-signature"
} = Astro.props;
---

<section class="border-t border-stone-200 py-24 bg-stone-50/50">
  <Container as="div">
    <div class="grid gap-16 lg:grid-cols-2 lg:items-center">
      <div class="order-2 lg:order-1">
        <p class="text-xs font-semibold uppercase tracking-widest text-stone-400">Battle of Origins</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-stone-900 md:text-5xl">
          {productA.name} <span class="text-stone-300">vs</span> {productB.name}
        </h2>
        <p class="mt-6 text-lg text-stone-500 leading-relaxed max-w-xl">
          Bingung memilih antara keasaman cerah Bali {productA.name} atau keseimbangan karamel {productB.name}? Kami membedah keduanya untuk membantu Anda memilih yang terbaik.
        </p>
        <div class="mt-10">
          <a href={href} class="ds-button-primary">
            Lihat Perbandingan Lengkap
          </a>
        </div>
      </div>
      
      <div class="order-1 lg:order-2 relative">
        <div class="aspect-[16/10] overflow-hidden rounded-[3rem] border border-stone-200 bg-white p-3 shadow-sm">
          <div class="grid h-full grid-cols-2 gap-3">
            <img src={productA.image} alt={productA.name} class="h-full w-full rounded-[2rem] object-cover" />
            <img src={productB.image} alt={productB.name} class="h-full w-full rounded-[2rem] object-cover" />
          </div>
          <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
            <div class="flex h-16 w-16 items-center justify-center rounded-full bg-stone-900 font-display text-xl font-bold text-white shadow-2xl border-4 border-white">
              VS
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
