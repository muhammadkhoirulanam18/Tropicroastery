---
import Container from "../components/Container.astro";

const images = [
  {
    src: "https://images.unsplash.com/photo-1447933601403-0c6688de566e?auto=format&fit=crop&w=800&q=75&fm=webp",
    alt: "Coffee beans roasting"
  },
  {
    src: "https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&w=800&q=75&fm=webp",
    alt: "Pour over brewing"
  },
  {
    src: "https://images.unsplash.com/photo-1511920170033-f8396924c348?auto=format&fit=crop&w=800&q=75&fm=webp",
    alt: "Coffee cup close up"
  },
  {
    src: "https://images.unsplash.com/photo-1459755486867-b55449bb39ff?auto=format&fit=crop&w=800&q=75&fm=webp",
    alt: "Specialty coffee origin"
  }
];
---

<section class="border-t border-stone-200 py-16">
  <Container as="div">
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
      {images.map((image) => (
        <figure class="overflow-hidden rounded-[2rem] border border-stone-100 bg-stone-50">
          <img
            src={image.src}
            alt={image.alt}
            class="aspect-square w-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
            decoding="async"
          />
        </figure>
      ))}
    </div>
  </Container>
</section>
