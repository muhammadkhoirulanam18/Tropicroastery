---
import Container from "../components/Container.astro";

interface Props {
  title?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  title = "Temukan kopi yang tepat untuk Anda.",
  description = "Setiap biji kopi kami disangrai dalam batch kecil untuk menjaga karakter rasa yang unik dari setiap origin.",
  ctaLabel = "Lihat Rekomendasi Kami",
  ctaHref = "/best/kopi-arabika-terbaik",
} = Astro.props;
---

<section class="border-t border-stone-100 py-16 md:py-24">
  <Container as="div">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="font-display text-2xl font-semibold tracking-tight text-stone-900 md:text-3xl">
        {title}
      </h2>
      <p class="mt-4 text-base text-stone-500 leading-relaxed">
        {description}
      </p>
      <div class="mt-8">
        <a href={ctaHref} class="ds-button-primary">
          {ctaLabel}
        </a>
      </div>
    </div>
  </Container>
</section>
