---
import Container from "../components/Container.astro";
import Badge from "../components/ui/Badge.astro";
import Button from "../components/ui/Button.astro";

const {
  eyebrow = "Specialty coffee",
  title = "Premium minimal coffee storefront for Tropic Roastery.",
  description = "Clean layout, premium whitespace, and reusable product cards built to showcase beans, brewing, and brand story without heavy JavaScript.",
  primaryHref = "/best/kopi-arabika-terbaik",
  primaryLabel = "Cek Biji Kopi Terbaik",
  secondaryHref = "#story",
  secondaryLabel = "Brand Story",
} = Astro.props;

const stats = [
  { value: "12+", label: "Single origin" },
  { value: "48h", label: "Fresh roast" },
  { value: "4.9", label: "Avg rating" },
];
---

<section class="ds-section">
  <Container as="div" class="text-center">
    <Badge label={eyebrow} />
    <h1 class="ds-heading mx-auto mt-8 max-w-4xl md:leading-tight">
      {title}
    </h1>
    <p class="ds-subheading mx-auto mt-5 max-w-2xl">
      {description}
    </p>
    <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
      <Button href={primaryHref} label={primaryLabel} variant="primary" />
      <Button href={secondaryHref} label={secondaryLabel} variant="secondary" />
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-3">
      {stats.map((stat) => (
        <div class="ds-surface px-6 py-5 text-left">
          <p class="text-2xl font-semibold tracking-tight text-neutral-900">{stat.value}</p>
          <p class="mt-1 text-sm text-neutral-500">{stat.label}</p>
        </div>
      ))}
    </div>
  </Container>
</section>
