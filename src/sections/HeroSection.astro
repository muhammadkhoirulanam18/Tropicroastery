---
import Container from "../components/Container.astro";

interface Props {
  label?: string;
  title?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  label = "Specialty Coffee · Single Origin",
  title = "Kopi yang berbicara sendiri.",
  description = "Kami memilih, menyangrai, dan mengirim biji kopi terbaik dari dataran tinggi Indonesia — langsung ke tangan Anda.",
  ctaLabel = "Lihat Pilihan Kopi",
  ctaHref = "/best/kopi-arabika-terbaik",
} = Astro.props;
---


<section class="py-16 md:py-24">
  <Container as="div">
    <div class="max-w-2xl">
      <p class="ds-kicker">{label}</p>

      <h1 class="mt-6 font-display text-4xl font-bold leading-[1.15] tracking-tight text-stone-900 md:text-5xl">
        {title}
      </h1>

      <p class="mt-6 text-lg leading-relaxed text-stone-500">
        {description}
      </p>

      <div class="mt-10">
        <a href={ctaHref} class="text-sm font-medium text-stone-900 underline underline-offset-4 decoration-stone-300 hover:decoration-stone-900">
          {ctaLabel} →
        </a>
      </div>
    </div>
  </Container>
</section>
