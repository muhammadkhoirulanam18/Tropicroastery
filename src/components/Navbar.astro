
---
import Container from "./Container.astro";

const links = [
  { href: "/", label: "Home" },
  { href: "/best/kopi-arabika-terbaik", label: "Beans" },
  { href: "/blog", label: "Journal" },
  { href: "/about", label: "Story" },
  { href: "/contact", label: "Contact" },
];
---

<nav class="fixed inset-x-0 top-0 z-50 bg-white/95 backdrop-blur-sm">
  <Container as="div">
    <div class="flex h-16 items-center justify-between">
      <!-- Wordmark -->
      <a href="/" class="font-display text-lg font-semibold tracking-tight text-stone-900">
        Tropic Roastery
      </a>

      <!-- Desktop links -->
      <div class="hidden items-center gap-8 md:flex">
        {links.map((link) => (
          <a
            href={link.href}
            class="text-sm text-stone-500 hover:text-stone-900"
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Mobile menu -->
      <details class="relative md:hidden">
        <summary class="list-none text-sm font-medium text-stone-500 cursor-pointer">
          Menu
        </summary>
        <div class="absolute right-0 mt-4 w-48 bg-white border border-stone-100 rounded-xl p-3 shadow-lg">
          <div class="flex flex-col gap-1">
            {links.map((link) => (
              <a
                href={link.href}
                class="rounded-lg px-4 py-2.5 text-sm text-stone-700 hover:bg-stone-50"
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </details>
    </div>
  </Container>
</nav>
