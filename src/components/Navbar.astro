---
import Container from "./Container.astro";

const links = [
  { href: "/", label: "Home" },
  { 
    label: "Shop Coffee", 
    children: [
      { href: "/best/kopi-arabika-terbaik", label: "Arabika" },
      { href: "/best/kopi-robusta-terbaik", label: "Robusta" },
      { href: "/best/kopi-blend-terbaik", label: "Blend" },
    ]
  },
  { 
    label: "Shop Tools", 
    children: [
      { href: "/best/brewing-tools", label: "Brewing Tools" },
      { href: "/best/grinders", label: "Grinders" },
      { href: "/best/espresso", label: "Espresso" },
      { href: "/best/accessories", label: "Accessories" },
    ]
  },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "Story" },
  { href: "/contact", label: "Contact" },
];
---

<nav class="fixed inset-x-0 top-0 z-50 bg-white/95 backdrop-blur-sm">
  <Container as="div">
    <div class="flex h-16 items-center justify-between">
      <!-- Wordmark -->
      <a href="/" class="font-display text-lg font-semibold tracking-tight text-stone-900">
        Tropic Roastery
      </a>

      <!-- Desktop links -->
      <div class="hidden items-center gap-8 md:flex">
        {links.map((link) => (
          link.children ? (
            <div class="group relative py-4">
              <button class="flex items-center gap-1 text-sm text-stone-500 hover:text-stone-900 focus:outline-none">
                {link.label}
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-40 transition-transform group-hover:rotate-180"><path d="m6 9 6 6 6-6"/></svg>
              </button>
              
              <div class="invisible absolute left-0 top-full w-48 translate-y-2 opacity-0 transition-all group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
                <div class="rounded-xl border border-stone-100 bg-white p-2 shadow-xl">
                  {link.children.map((child) => (
                    <a
                      href={child.href}
                      class="block rounded-lg px-4 py-2.5 text-sm text-stone-600 hover:bg-stone-50 hover:text-stone-900"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class="text-sm text-stone-500 hover:text-stone-900"
            >
              {link.label}
            </a>
          )
        ))}
      </div>

      <!-- Mobile menu -->
      <details class="relative md:hidden">
        <summary class="list-none text-sm font-medium text-stone-500 cursor-pointer">
          Menu
        </summary>
        <div class="absolute right-0 mt-4 w-56 bg-white border border-stone-100 rounded-xl p-3 shadow-lg">
          <div class="flex flex-col gap-1">
            {links.map((link) => (
              link.children ? (
                <div class="py-2">
                  <span class="px-4 text-[10px] font-bold uppercase tracking-widest text-stone-400">
                    {link.label}
                  </span>
                  <div class="mt-1 flex flex-col gap-1">
                    {link.children.map((child) => (
                      <a
                        href={child.href}
                        class="rounded-lg px-4 py-2.5 text-sm text-stone-700 hover:bg-stone-50"
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              ) : (
                <a
                  href={link.href}
                  class="rounded-lg px-4 py-2.5 text-sm text-stone-700 hover:bg-stone-50"
                >
                  {link.label}
                </a>
              )
            ))}
          </div>
        </div>
      </details>
    </div>
  </Container>
</nav>

