---
interface Props {
  title: string;
  excerpt: string;
  href: string;
  category?: string;
  date?: string;
  image?: string;
  imageAlt?: string;
}

const {
  title,
  excerpt,
  href,
  category = "Kopi",
  date,
  image,
  imageAlt = title,
} = Astro.props;
---

<article class="group flex flex-col gap-4">
  <!-- Image -->
  {image && (
    <a href={href} class="block overflow-hidden rounded-sm bg-stone-100 mb-2" tabindex="-1" aria-hidden="true">
      <img
        src={image}
        alt={imageAlt}
        class="aspect-[3/2] w-full object-cover"
        loading="lazy"
        decoding="async"
      />
    </a>
  )}

  <!-- Meta -->
  <div class="flex items-center gap-3 text-xs font-medium uppercase tracking-[0.12em] text-stone-400">
    <span>{category}</span>
    {date && (
      <>
        <span>·</span>
        <time datetime={date}>{date}</time>
      </>
    )}
  </div>

  <!-- Title -->
  <h3 class="font-display text-lg font-semibold leading-snug text-stone-900 md:text-xl">
    <a href={href} class="hover:text-stone-600">
      {title}
    </a>
  </h3>

  <!-- Excerpt -->
  <p class="text-sm leading-relaxed text-stone-500 line-clamp-2">
    {excerpt}
  </p>

  <!-- Read link -->
  <a
    href={href}
    class="mt-1 text-sm font-medium text-stone-900 underline underline-offset-4 decoration-stone-300 hover:decoration-stone-900"
    aria-label={`Baca artikel: ${title}`}
  >
    Baca Artikel
  </a>
</article>
