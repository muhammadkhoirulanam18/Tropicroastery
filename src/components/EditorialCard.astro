---
/**
 * EditorialCard.astro
 * A premium, typography-focused card designed for editorial product showcases.
 * Avoids the "ecommerce marketplace" look by using spacious layout and minimal UI noise.
 */
import Badge from "./ui/Badge.astro";

interface Props {
  title: string;
  subtitle?: string;
  price?: string;
  image: string;
  href: string;
  badge?: string;
  badgeTone?: "accent" | "neutral" | "success";
  aspectRatio?: "square" | "portrait" | "video";
}

const { 
  title, 
  subtitle, 
  price, 
  image, 
  href, 
  badge, 
  badgeTone = "neutral",
  aspectRatio = "portrait" 
} = Astro.props;

const aspectClasses = {
  square: "aspect-square",
  portrait: "aspect-[4/5]",
  video: "aspect-video",
};
---

<article class="group flex flex-col gap-5">
  <a href={href} class="relative block overflow-hidden rounded-lg bg-stone-100">
    {badge && (
      <div class="absolute left-4 top-4 z-10">
        <Badge label={badge} tone={badgeTone} />
      </div>
    )}
    <img
      src={image}
      alt={title}
      class={`w-full object-cover transition-transform duration-700 group-hover:scale-105 ${aspectClasses[aspectRatio]}`}
      loading="lazy"
      decoding="async"
    />
  </a>

  <div class="flex flex-col gap-2">
    {subtitle && (
      <span class="ds-kicker text-[10px]">{subtitle}</span>
    )}
    
    <div class="flex items-baseline justify-between gap-4">
      <h3 class="font-display text-xl font-medium tracking-tight text-stone-900 md:text-2xl">
        <a href={href} class="hover:text-stone-600 transition-colors">
          {title}
        </a>
      </h3>
      {price && (
        <span class="font-display text-sm font-semibold text-stone-500 tabular-nums">
          {price}
        </span>
      )}
    </div>

    <a href={href} class="mt-2 text-xs font-semibold uppercase tracking-widest text-stone-900 underline underline-offset-8 decoration-stone-200 hover:decoration-stone-900 transition-all">
      Lihat Detail
    </a>
  </div>
</article>
