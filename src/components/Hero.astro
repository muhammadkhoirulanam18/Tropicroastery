---
const {
  eyebrow = "Coffee storefront",
  title = "A sleek Astro storefront for modern coffee products.",
  description = "Minimal layout, clean spacing, and a focused product experience built for conversion.",
  primaryHref = "#products",
  primaryLabel = "Lihat Koleksi",
  secondaryHref = "/about",
  secondaryLabel = "Tentang Toko",
} = Astro.props;
---

<section class="px-4 py-24 md:py-32">
  <div class="mx-auto max-w-3xl text-center">
    <p class="inline-flex items-center rounded-full border border-orange-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-orange-500 shadow-sm">
      {eyebrow}
    </p>
    <h1 class="mt-8 text-5xl font-semibold tracking-tight text-neutral-900 md:text-6xl md:leading-tight">
      {title}
    </h1>
    <p class="mx-auto mt-5 max-w-2xl text-sm leading-7 text-neutral-500 md:text-base">
      {description}
    </p>
    <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
      <a
        href={primaryHref}
        class="inline-flex items-center justify-center rounded-full bg-orange-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-orange-600"
      >
        {primaryLabel}
      </a>
      <a
        href={secondaryHref}
        class="inline-flex items-center justify-center rounded-full border border-neutral-200 bg-white px-6 py-3 text-sm font-semibold text-neutral-900 transition hover:border-neutral-300 hover:bg-neutral-50"
      >
        {secondaryLabel}
      </a>
    </div>
  </div>
</section>
