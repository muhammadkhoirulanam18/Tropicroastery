---
import Badge from "./ui/Badge.astro";
import Button from "./ui/Button.astro";

const {
  title,
  price,
  description,
  image,
  href = "#contact",
  badge = "Most Popular",
  roastLevel = "Medium Roast",
  flavorNotes = "Chocolate, caramel, citrus",
  rating = 4.8,
} = Astro.props;
---

<article class="ds-card ds-card-hover flex h-full flex-col">
  <a href={href} class="block overflow-hidden">
    <img 
      src={image} 
      alt={title} 
      class="aspect-[4/4] w-full object-cover transition-transform duration-500 hover:scale-105" 
      loading="lazy" 
      decoding="async" 
    />
  </a>
  
  <div class="flex flex-1 flex-col p-6">
    <div class="mb-4">
      {badge && <Badge label={badge} />}
    </div>

    <div class="flex items-start justify-between gap-4">
      <h3 class="font-display text-lg font-semibold text-stone-900">{title}</h3>
      <span class="shrink-0 text-sm font-bold text-orange-600">{price}</span>
    </div>

    <div class="mt-1.5 flex items-center gap-1 text-xs">
      <span class="text-orange-400">★</span>
      <span class="font-medium text-stone-500">{rating}</span>
    </div>

    <p class="mt-4 text-sm leading-relaxed text-stone-500 line-clamp-2">
      {description}
    </p>

    <div class="mt-4 flex flex-wrap gap-2">
      <span class="ds-chip">{roastLevel}</span>
      <span class="ds-chip">{flavorNotes}</span>
    </div>

    <div class="mt-auto pt-8">
      <Button href={href} label="Cek Harga" variant="primary" />
    </div>
  </div>
</article>
