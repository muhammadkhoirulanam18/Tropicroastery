---
import Badge from "./ui/Badge.astro";
import Button from "./ui/Button.astro";

const {
  title,
  price,
  description,
  image,
  href = "#contact",
  badge = "Most Popular",
  roastLevel = "Medium Roast",
  flavorNotes = "Chocolate, caramel, citrus",
  rating = 4.8,
} = Astro.props;
---

<article class="ds-card ds-card-hover">
  <a href={href} class="block">
    <img src={image} alt={title} class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async" />
  </a>
  <div class="space-y-5 p-6">
    <div class="flex items-start justify-between gap-4">
      <div class="space-y-2">
        <Badge label={badge} />
        <h3 class="text-base font-medium text-neutral-900">{title}</h3>
      </div>
      <div class="flex flex-col items-end gap-1">
        <span class="shrink-0 text-sm font-semibold text-orange-500">{price}</span>
        <div class="flex items-center gap-1 text-[10px] font-bold text-orange-400">
          <span>★</span>
          <span>{rating}</span>
        </div>
      </div>
    </div>
    <p class="text-sm leading-6 text-neutral-500">{description}</p>
    <div class="flex flex-wrap gap-2">
      <span class="ds-chip">{roastLevel}</span>
      <span class="ds-chip">{flavorNotes}</span>
    </div>
    <Button href={href} label="Cek Harga" variant="primary" />
  </div>
</article>
