---
interface Props {
  name: string;
  description: string;
  href: string;
  count?: string;
}

const { name, description, href, count } = Astro.props;
---

<article class="group relative flex flex-col justify-end overflow-hidden rounded-[2rem] border border-stone-200 bg-white p-8 transition-all duration-300 hover:border-orange-200 hover:shadow-xl hover:shadow-orange-500/5">
  <div class="flex flex-col gap-4">
    {count && (
      <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-stone-400">
        {count}
      </span>
    )}
    
    <h3 class="font-display text-2xl font-bold tracking-tight text-stone-900 group-hover:text-orange-600 transition-colors">
      <a href={href} class="after:absolute after:inset-0">
        {name}
      </a>
    </h3>
    
    <p class="text-sm leading-relaxed text-stone-500 line-clamp-2">
      {description}
    </p>

    <div class="mt-2 flex items-center gap-2 text-xs font-bold text-stone-900 group-hover:text-orange-600">
      <span>Lihat Koleksi</span>
      <span class="transition-transform group-hover:translate-x-1">→</span>
    </div>
  </div>
</article>
