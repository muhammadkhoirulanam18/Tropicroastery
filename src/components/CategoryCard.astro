---
interface Props {
  name: string;
  description: string;
  href: string;
  count?: string;
}

const { name, description, href, count } = Astro.props;
---

<article class="group relative border-t border-stone-100 py-8">
  <a href={href} class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between after:absolute after:inset-0">
    <div class="flex flex-col gap-1.5 md:flex-row md:items-center md:gap-6">
      <h3 class="font-display text-lg font-semibold text-stone-900 group-hover:text-stone-600 md:text-xl">
        {name}
      </h3>
      {count && (
        <span class="text-xs font-medium uppercase tracking-[0.12em] text-stone-400">
          {count}
        </span>
      )}
    </div>

    <p class="text-sm text-stone-500 md:max-w-xs md:text-right">
      {description}
    </p>
  </a>
</article>
